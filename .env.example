# Required
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Pi agent configuration
PI_BIN=pi
PI_MODEL=
PI_THINKING=
PI_CWD=/home/ubuntu
PI_EXTRA_FLAGS=

# Gateway behavior
TRIGGER_NAME=Andy
MAX_CONCURRENCY=3
POLL_INTERVAL_MS=1000
AUTO_REGISTER_DMS=true

# Storage
SESSIONS_DIR=./sessions
DB_PATH=./gateway.db

# Logging
LOG_LEVEL=info
